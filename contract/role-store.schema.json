{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Slice",
  "description": "The on-disk role slice as Census reads it: the role-wide top level (whose\nkeys Census ignores) plus the optional `[payload]` table it consumes.\nTolerant (no `deny_unknown_fields`) so foreign adapter fields are skipped.\nThis is the schema root for `contract/role-store.schema.json`. `pub` so the\ninterface-contract test can schematize it.",
  "type": "object",
  "properties": {
    "payload": {
      "anyOf": [
        {
          "$ref": "#/$defs/SlicePayload"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "Limits": {
      "description": "systemd/rlimit composition subset Census consumes.",
      "type": "object",
      "properties": {
        "nofile": {
          "description": "`RLIMIT_NOFILE`.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        },
        "nproc": {
          "description": "`RLIMIT_NPROC`.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        }
      }
    },
    "PermissionRef": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            }
          },
          "required": [
            "id"
          ]
        }
      ]
    },
    "SlicePayload": {
      "description": "The `[payload]` subset Census reads from a role slice. Tolerant: unknown\nkeys are ignored (Census reads only the Linux/payload subset of a format\nTessera owns). `pub` so the interface-contract test can schematize it.",
      "type": "object",
      "properties": {
        "groups": {
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        },
        "limits": {
          "anyOf": [
            {
              "$ref": "#/$defs/Limits"
            },
            {
              "type": "null"
            }
          ]
        },
        "permissions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/PermissionRef"
          }
        },
        "sudo_role": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    }
  }
}